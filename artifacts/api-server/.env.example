# Backend (API server) env example

# Server
PORT=3001

# SMTP (for contact form emails)
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Where to send contact form messages
# If empty, CONTACT_TO_EMAIL defaults to SMTP_USER
CONTACT_TO_EMAIL=

# CORS / Origins
# Frontend deployed origin (used if you add CORS allowlist later)
FRONTEND_ORIGIN=https://digital-shine.netlify.app

